APP_ENV=development
APP_NAME=CareerOS
APP_HOST=0.0.0.0
APP_PORT=8000
API_TOKEN=replace-with-a-strong-local-token
DATABASE_URL=postgresql+psycopg://careeros:replace-with-a-strong-password@db:5432/careeros
POSTGRES_DB=careeros
POSTGRES_USER=careeros
POSTGRES_PASSWORD=replace-with-a-strong-password
STORAGE_ROOT=/app/data/incoming
MAX_UPLOAD_SIZE_BYTES=10485760
# EMBEDDING_PROVIDER can be deterministic or sentence-transformers.
# Use deterministic for fast demos/tests; use sentence-transformers for real local semantic matching.
EMBEDDING_PROVIDER=deterministic
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_VERSION=bge-small-en-v1.5:sentence-transformers:v1
EMBEDDING_DIMENSION=64
SCORING_VERSION=hybrid:v1
